AUTOSTOCK_DATA_DIR=/app/data
AUTOSTOCK_SQLITE_PATH=/app/data/app.db
AUTOSTOCK_MARKET_DUCKDB_PATH=/app/data/market.duckdb
AUTOSTOCK_FRONTEND_DIST_PATH=/app/frontend_dist
AUTOSTOCK_TAVILY_API_KEY=
AUTOSTOCK_TAVILY_DEFAULT_SEARCH_DEPTH=basic
AUTOSTOCK_TAVILY_DEFAULT_TOPIC=finance
AUTOSTOCK_TAVILY_DEFAULT_MAX_RESULTS=5
AUTOSTOCK_TAVILY_CACHE_TTL_SECONDS=1800

# Sensitive local LLM raw API JSONL logs. Disabled by default.
# These logs intentionally include full provider config, API keys, prompts,
# request/response bodies, stream chunks, errors, tool arguments, and tool results.
AUTOSTOCK_LLM_RAW_LOG_ENABLED=0
AUTOSTOCK_LLM_RAW_LOG_DIR=logs
